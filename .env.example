# GLPI
GLPI_URL=http://192.168.1.100/apirest.php
GLPI_USER_TOKEN=abcdef1234567890abcdef1234567890abcdef12
GLPI_APP_TOKEN=zxcvbn0987654321zxcvbn0987654321zxcvbn09

# LDAP / Active Directory
LDAP_HOST=mondomaine.local
LDAP_PORT=389
LDAP_BASE_DN=dc=mondomaine,dc=local
LDAP_BIND_USER=CN=svc-glpi-api,OU=Services,DC=mondomaine,DC=local
LDAP_BIND_PASSWORD=MotDePasseServiceCompte!

# JWT
# Générer une clé avec : python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=remplacer_par_une_cle_aleatoire_generee_avec_python_secrets
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/glpi_api.log
